    def Xform "Realsense_front" (
        prepend references = @http://omniverse-content-production.s3-us-west-2.amazonaws.com/Assets/Isaac/4.2/Isaac/Sensors/Intel/RealSense/rsd455.usd@
    )
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        double3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (0.29, 0, 0.217)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        over "RSD455"
        {
            over "Camera_Pseudo_Depth"
            {
                float2 clippingRange = (0.01, 1000000)
            }

            over "Camera_OmniVision_OV9782_Color"
            {
                float2 clippingRange = (0.01, 1000000)
            }
        }
    }

    def "RPLIDAR_front" (
        delete payload = [
            @../../../../Simulation/Slamtec/RPLIDAR.usd@,
            @./RPLIDAR.usd@
        ]
        prepend references = @./RPLIDAR.usd@
    )
    {
        quatd xformOp:orient = (1, 0, 0, 0)
        double3 xformOp:scale = (1, 1, 1)
        double3 xformOp:translate = (0.295, 0, 0.175)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]

        over "RPLIDAR_S2e" (
            prepend apiSchemas = ["PhysicsRigidBodyAPI", "PhysxRigidBodyAPI", "PhysicsMassAPI"]
        )
        {
            bool physics:kinematicEnabled = 0
            float physics:mass = 0.15
            bool physics:rigidBodyEnabled = 1
        }
    }
