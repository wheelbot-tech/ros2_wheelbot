<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  
    
    <xacro:macro name="virtual_bicycle_module" params="
        prefix parent
         pos_z"
    >
    
    <!-- virtual rear wheel -->

    <link name="${prefix}virtual_traction_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="0.01" radius="${wheel_radius}"/>
        </geometry>
        <material name="invisible"/>
      </visual>
    </link>

    <joint name="${prefix}virtual_traction_wheel_joint" type="continuous">
      <parent link="${prefix}${parent}"/>
      <child link="${prefix}virtual_traction_wheel"/>
      <origin xyz="-${wheelbase/2} 0 -${pos_z}" rpy="0 0 ${PI/2}"/>
      <axis xyz="1 0 0"/>
      <limit effort="100.0" velocity="100.0"/>
      <dynamics damping="0.2"/>
    </joint>


    <!-- virtual front wheel -->

    <link name="${prefix}virtual_steering_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="0.01" radius="${wheel_radius}"/>
        </geometry>
        <material name="invisible"/>
      </visual>
    </link>

    <joint name="${prefix}virtual_steering_wheel_joint" type="revolute">
      <parent link="${prefix}${parent}"/>
      <child link="${prefix}virtual_steering_wheel"/>
      <origin xyz="${base_width/2} 0 -${pos_z}" rpy="0 0 ${PI/2}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.0" upper="1.0" effort="100.0" velocity="0.0"/>
      <dynamics damping="0.2"/>
    </joint>
      
  </xacro:macro>
</robot>
