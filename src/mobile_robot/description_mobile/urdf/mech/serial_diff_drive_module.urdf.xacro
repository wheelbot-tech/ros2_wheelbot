<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="serial_diff_drive_module" params="
      prefix name parent *origin
      drive_pos steering_pos namespace
      steering_mimic_offset:=0.0">

    <link name="${prefix}${drive_pos}steering_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="${rulment_axial_height}" radius="${rulment_axial_diametru}"/>
        </geometry>
        <material name="Rubber"/>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${rulment_axial_height}" radius="${rulment_axial_diametru}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}${drive_pos}steering_joint" type="revolute">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}${drive_pos}steering_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="-${PI}" upper="${PI}" effort="100.0" velocity="100.0"/>
      <dynamics damping="0.2"/>
    </joint>

    <link name="${prefix}${drive_pos}chassis_2_link">
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.16 0.09"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.09 0.16 0.09"/>
        </geometry>
        <material name="Aluminium"/>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${base_mass}"/>
        <inertia
          ixx="0.000270" ixy="0.0" ixz="0.0"
          iyy="0.000270" iyz="0.0"
          izz="0.000426"/>
      </inertial>
    </link>

    <joint name="${prefix}${drive_pos}chassis_2_joint" type="fixed">
      <origin xyz="0 0 -${rulment_axial_height/2 + wheel_radius}" rpy="0 0 0"/>
      <parent link="${prefix}${drive_pos}steering_link"/>
      <child link="${prefix}${drive_pos}chassis_2_link"/>
    </joint>

    <link name="${prefix}${drive_pos}wheel_drive_left">
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
        </geometry>
        <material name="PETG_orange"/>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"
          ixy="0" ixz="0"
          iyy="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"
          iyz="0"
          izz="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"/>
      </inertial>
    </link>

    <joint name="${prefix}${drive_pos}drive_left_joint" type="continuous">
      <origin xyz="0 ${wheel_drive_len/2} 0" rpy="0 0 ${PI/2}"/>
      <parent link="${prefix}${drive_pos}chassis_2_link"/>
      <child link="${prefix}${drive_pos}wheel_drive_left"/>
      <axis xyz="1 0 0"/>
      <limit effort="100.0" velocity="100.0"/>
      <dynamics damping="0.2"/>
    </joint>

    <link name="${prefix}${drive_pos}wheel_drive_right">
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry>
          <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
        </geometry>
        <material name="PETG_orange"/>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"
          ixy="0" ixz="0"
          iyy="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"
          iyz="0"
          izz="${(2/5) * wheel_mass * (wheel_radius * wheel_radius)}"/>
      </inertial>
    </link>

    <joint name="${prefix}${drive_pos}drive_right_joint" type="continuous">
      <origin xyz="0 -${wheel_drive_len/2} 0" rpy="0 0 ${PI/2}"/>
      <parent link="${prefix}${drive_pos}chassis_2_link"/>
      <child link="${prefix}${drive_pos}wheel_drive_right"/>
      <axis xyz="1 0 0"/>
      <limit effort="100.0" velocity="100.0"/>
      <dynamics damping="0.2"/>
    </joint>
  </xacro:macro>
</robot>
