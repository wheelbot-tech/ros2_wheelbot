<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  
    
    <xacro:macro name="virtual_ackermann_module" params="
        prefix parent
        pos_x pos_y pos_z"
    >
    
   <!-- virtual front wheels -->

    <link name="${prefix}virtual_left_steering_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="0.01" radius="${wheel_radius}"/>
        </geometry>
        <material name="invisible"/>
      </visual>
    </link>

    <joint name="${prefix}virtual_left_steering_joint" type="revolute">
      <parent link="${prefix}${parent}"/>
      <child link="${prefix}virtual_left_steering_wheel"/>
      <origin xyz="${pos_x} ${pos_y} -${pos_z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.0" upper="1.0" effort="100.0" velocity="0.0"/>
      <dynamics damping="0.2"/>
    </joint>

    <link name="${prefix}virtual_right_steering_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI/2}"/>
        <geometry>
          <cylinder length="0.01" radius="${wheel_radius}"/>
        </geometry>
        <material name="invisible"/>
      </visual>
    </link>

    <joint name="${prefix}virtual_right_steering_joint" type="revolute">
      <parent link="${prefix}${parent}"/>
      <child link="${prefix}virtual_right_steering_wheel"/>
      <origin xyz="${pos_x} -${pos_y} -${pos_z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.0" upper="1.0" effort="100.0" velocity="0.0"/>
      <dynamics damping="0.2"/>
    </joint>
  </xacro:macro>
</robot>
