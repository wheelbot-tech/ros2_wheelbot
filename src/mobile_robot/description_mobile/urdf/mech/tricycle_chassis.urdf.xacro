<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">


    <xacro:macro name="tricycle_chassis" params="
        name
        prefix
        parent
        *origin "
    >

    <link name="${prefix}base_link">
    <inertial>
        <origin xyz="-0.12402708078366961 0.00015404541391043106 0.1492367901975126" rpy="0 0 0"/>
        <mass value="77.40513448934979"/>
        <inertia ixx="1.507219" iyy="1.708811" izz="2.684961" ixy="-0.000443" iyz="-0.000657" ixz="-0.278399"/>
    </inertial>
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Aluminium"/>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
    </link>

    <joint name="${prefix}base_joint" type="fixed">
        <xacro:insert_block name="origin" />
        <parent link="${parent}"/>
        <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}right_wheel">
    <inertial>
        <origin xyz="0.0 -0.019999999999999962 -1.3877787807814457e-17" rpy="0 0 0"/>
        <mass value="6.313344596654048"/>
        <inertia ixx="0.010943" iyy="0.020203" izz="0.010943" ixy="0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
        <origin xyz="0.175 0.19 -0.08" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/caster_wheel_right.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Rubber"/>
    </visual>
    <collision>
        <origin xyz="0.175 0.19 -0.08" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/caster_wheel_right.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
    </link>

    <joint name="${prefix}right_wheel_joint" type="continuous">
    <origin xyz="-0.175 -0.19 0.08" rpy="0 0 0"/>
    <parent link="${prefix}base_link"/>
    <child link="${prefix}right_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    </joint>

    <link name="${prefix}left_wheel">
    <inertial>
        <origin xyz="0.0 0.019999999999999962 0.0" rpy="0 0 0"/>
        <mass value="6.313344596654048"/>
        <inertia ixx="0.010943" iyy="0.020203" izz="0.010943" ixy="-0.0" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
        <origin xyz="0.175 -0.19 -0.08" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/caster_wheel_left.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="Rubber"/>
    </visual>
    <collision>
        <origin xyz="0.175 -0.19 -0.08" rpy="0 0 0"/>
        <geometry>
        <mesh filename="file://$(find description)/meshes/caster_wheel_left.stl" scale="0.001 0.001 0.001"/>
        </geometry>
    </collision>
    </link>

    <joint name="${prefix}left_wheel_joint" type="continuous">
    <origin xyz="-0.175 0.19 0.08" rpy="0 0 0"/>
    <parent link="${prefix}base_link"/>
    <child link="${prefix}left_wheel"/>
    <axis xyz="0.0 1.0 0.0"/>
    </joint>

    </xacro:macro>
</robot>